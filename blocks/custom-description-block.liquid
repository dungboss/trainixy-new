<div
  {{ block.shopify_attributes }}
  style="--margin-top: {{ block.settings.margin_top | divided_by: 10.0 }}rem;--margin-bottom: {{ block.settings.margin_bottom | divided_by: 10.0 }}rem;"
>
<div id="custom-product-description" class="custom-product-description">
      {% if block.settings.heading != blank %}
    <h4 class="custom-description-heading">{{block.settings.heading}}</h4>
  {% endif %}
     {% if block.settings.description_text != blank %}
    <p class="custom-description-text">
      {{block.settings.description_text}}
    </p>
        {% endif %}
    <ul role="list" class="custom-list">
      
      {% if block.settings.checkmark1 != blank %}
        <li class="custom-list-item">
            <i class="fa-regular fa-circle-check custom-checkmark-icon" style="color:{{block.settings.checkmarkcolor}}"></i>
            <div class="custom-list-item-text"><strong>{{block.settings.checkmark1}}</strong></div>
        </li>
       {% endif %}

        {% if block.settings.checkmark2 != blank %}
        <li class="custom-list-item">
          <i class="fa-regular fa-circle-check custom-checkmark-icon" style="color:{{block.settings.checkmarkcolor}}"></i>
             <div class="custom-list-item-text"><strong>{{block.settings.checkmark2}}</strong></div>
        </li>
         {% endif %}

          {% if block.settings.checkmark3 != blank %}
        <li class="custom-list-item">
               <i class="fa-regular fa-circle-check custom-checkmark-icon" style="color:{{block.settings.checkmarkcolor}}"></i>
              <div class="custom-list-item-text"><strong>{{block.settings.checkmark3}}</strong></div>
        </li>
         {% endif %}

            {% if block.settings.checkmark4 != blank %}
        <li class="custom-list-item">
             <i class="fa-regular fa-circle-check custom-checkmark-icon" style="color:{{block.settings.checkmarkcolor}}"></i>
            <div class="custom-list-item-text"><strong>{{block.settings.checkmark4}}</strong></div>
        </li>
         {% endif %}

              {% if block.settings.checkmark5 != blank %}
         <li class="custom-list-item">
            <i class="fa-regular fa-circle-check custom-checkmark-icon" style="color:{{block.settings.checkmarkcolor}}"></i>
            <div class="custom-list-item-text"><strong>{{block.settings.checkmark5}}</strong></div>
        </li>
           {% endif %}
      
    </ul>
</div>

</div>  


<style>
    .custom-product-description {
        background-color: {{block.settings.customdescriptionbackground}};
        padding: 20px;
        border-radius: {{block.settings.borderradius}}px;
        margin-top: 20px;
    }

    .custom-description-heading {
        font-size: {{block.settings.headingfontsize}}px;
        font-weight: bold;
        margin-bottom: 10px;
    }

    .custom-description-text {
        margin-bottom: 20px;
        line-height: 1.6;
        font-size: {{block.settings.description_textfontsize}}px;
    }

    .custom-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .custom-list-item {
        display: flex;
        align-items: center;
        margin-bottom: 10px;
    }

    .custom-checkmark-icon {
        width: 15px;
        height: 15px;
        margin-right: 10px;
    }

    .custom-list-item-text strong {
        font-size: {{block.settings.description_checkmarkfontsize}}px;
        color: #333333;
        line-height: 1.2;
    }
</style>

{% schema %}
{
  "name": "Custom Description Block",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product Features"
    },
    {
      "type": "richtext",
      "id": "description_text",
      "label": "Description text",
      "default": "<p>Add your product description here.</p>"
    },
    {
      "type": "text",
      "id": "checkmark1",
      "label": "Checkmark 1",
      "default": "Feature 1"
    },
    {
      "type": "text",
      "id": "checkmark2",
      "label": "Checkmark 2",
      "default": "Feature 2"
    },
    {
      "type": "text",
      "id": "checkmark3",
      "label": "Checkmark 3",
      "default": "Feature 3"
    },
    {
      "type": "text",
      "id": "checkmark4",
      "label": "Checkmark 4",
      "default": "Feature 4"
    },
    {
      "type": "text",
      "id": "checkmark5",
      "label": "Checkmark 5",
      "default": "Feature 5"
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "color",
      "id": "customdescriptionbackground",
      "label": "Background color",
      "default": "#f8f8f8"
    },
    {
      "type": "color",
      "id": "checkmarkcolor",
      "label": "Checkmark color",
      "default": "#00ff00"
    },
    {
      "type": "range",
      "id": "borderradius",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Border radius",
      "default": 8
    },
    {
      "type": "range",
      "id": "headingfontsize",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Heading font size",
      "default": 20
    },
    {
      "type": "range",
      "id": "description_textfontsize",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Description font size",
      "default": 16
    },
    {
      "type": "range",
      "id": "description_checkmarkfontsize",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Checkmark font size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Margins"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top",
      "min": 0,
      "max": 45,
      "step": 3,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 45,
      "step": 3,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Custom Description Block",
      "category": "Product"
    }
  ]
}
{% endschema %}
