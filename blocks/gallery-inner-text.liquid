<div
  {{ block.shopify_attributes }}
  style="--margin-top: {{ block.settings.margin_top | divided_by: 10.0 }}rem;--margin-bottom: {{ block.settings.margin_bottom | divided_by: 10.0 }}rem;"
>
  {% if block.settings.enablegallerybottomtext %}
    <div class="custom-gallery-text-wapper">
      <div class="custom-gallery-inner-wapper">
        <div class="custom-inner-text">
          <span> 
            {{block.settings.galleryinnertext}}
            
            {% if block.settings.enablegalleryreviewstars %}
              <span class="gallery-stars">
                {% for i in (1..5) %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 576 512" fill="{{block.settings.starcolor}}">
                    <path d="M316.9 18C311.6 7 300.4 0 288.1 0s-23.4 7-28.8 18L195 150.3 51.4 171.5c-12 1.8-22 10.2-25.7 21.7s-.7 24.2 7.9 32.7L137.8 329 113.2 474.7c-2 12 3 24.2 12.9 31.3s23 8 33.8 2.3l128.3-68.5 128.3 68.5c10.8 5.7 23.9 4.9 33.8-2.3s14.9-19.3 12.9-31.3L438.5 329 542.7 225.9c8.6-8.5 11.7-21.2 7.9-32.7s-13.7-19.9-25.7-21.7L381.2 150.3 316.9 18z"/>
                  </svg>
                {% endfor %}
              </span>
            {% endif %}
          </span>
        </div>
      </div>
    </div>
  {% endif %}
</div>

<style>
  .custom-gallery-text-wapper {
    width: 100%;
    margin-top: var(--margin-top, 2.4rem);
    margin-bottom: var(--margin-bottom, 2.4rem);
  }

  .custom-inner-text {
    display: flex;
    gap: 0px;
    align-items: center;
    font-size: 14px;
    background: {{block.settings.galleryinnerbackground}};
    justify-content: center;
    padding: 11px 10px;
    border-radius: {{block.settings.galleryinnerradius }}px;
    color: {{block.settings.galleryinnertextcolor }};
    opacity: {{block.settings.galleryinneropacity }};
  }

  .custom-gallery-inner-wapper {
    max-width: 330px;
    margin: 0 auto;
  }

  .gallery-stars {
    display: inline-flex;
    gap: 2px;
    align-items: center;
    margin-left: 5px;
  }

  .gallery-stars svg {
    display: block;
  }

  /* When used inside product gallery, position absolutely */
  .product-gallery__ar-wrapper .custom-gallery-text-wapper {
    position: absolute;
    top: {{block.settings.galleryinnerheight }}%;
    left: 0px;
    right: 0;
    z-index: 9;
    margin: 0;
  }
</style>

{% schema %}
{
  "name": "Gallery Inner Text",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "enablegallerybottomtext",
      "label": "Enable gallery text",
      "default": true
    },
    {
      "type": "text",
      "id": "galleryinnertext",
      "label": "Gallery text",
      "default": "5-Star Rated Product"
    },
    {
      "type": "checkbox",
      "id": "enablegalleryreviewstars",
      "label": "Show review stars",
      "default": true
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "color",
      "id": "starcolor",
      "label": "Star color",
      "default": "#FFD700"
    },
    {
      "type": "color",
      "id": "galleryinnerbackground",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "galleryinnertextcolor",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "galleryinneropacity",
      "min": 0.1,
      "max": 1.0,
      "step": 0.1,
      "label": "Opacity",
      "default": 0.8
    },
    {
      "type": "range",
      "id": "galleryinnerheight",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Position from top",
      "default": 80
    },
    {
      "type": "range",
      "id": "galleryinnerradius",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Border radius",
      "default": 8
    },
    {
      "type": "header",
      "content": "Margins"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top",
      "min": 0,
      "max": 45,
      "step": 3,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 45,
      "step": 3,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Gallery Inner Text",
      "category": "Product"
    }
  ]
}
{% endschema %}
