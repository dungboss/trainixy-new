<div
  {{ block.shopify_attributes }}
  style="--margin-top: {{ block.settings.margin_top | divided_by: 10.0 }}rem;--margin-bottom: {{ block.settings.margin_bottom | divided_by: 10.0 }}rem;"
>
<li class="flex justify-between">
    <div class="content_box rte" style="margin-right:15px">
    
      
      <p style="font-size:13px" class="prod__description"> <strong> <span class="highlight">{{block.settings.giftheadline}}</span> <br></strong> {{block.settings.gifttext}}
    </p></div>

  
<div class="img_box" style="width:40%"><img src="{{block.settings.giftimage | img_url: 'compact'}}"></div>
 



</li>
</div>



<style>
.highlight {
    box-shadow: inset 0 -2px {{block.settings.highlight}};
    color: inherit;
    text-decoration: none;
}
.justify-between {
    justify-content: space-between;
}
.flex {
    display: flex;
}

</style>

{% schema %}
{
  "name": "Gift Info",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "giftheadline",
      "label": "Gift headline",
      "default": "Perfect Gift"
    },
    {
      "type": "text",
      "id": "gifttext",
      "label": "Gift text",
      "default": "This makes a wonderful gift for any occasion."
    },
    {
      "type": "image_picker",
      "id": "giftimage",
      "label": "Gift image"
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "color",
      "id": "highlight",
      "label": "Highlight color",
      "default": "#ffc107"
    },
    {
      "type": "header",
      "content": "Margins"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top",
      "min": 0,
      "max": 45,
      "step": 3,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 45,
      "step": 3,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Gift Info",
      "category": "Product"
    }
  ]
}
{% endschema %}
