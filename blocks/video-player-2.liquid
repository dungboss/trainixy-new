<div class="video-container">
  {% if block.settings.video2 != blank %}
    <internal-video
      class="internal-video{% if block.settings.muted_autoplay2 %} internal-video--playing internal-video--muted{% endif %}"
      data-autoplay="{{ block.settings.muted_autoplay2 }}"
    >
      {% liquid
        if block.settings.thumbnail2 != blank
          assign videothumbnail = block.settings.thumbnail2
        else
          assign videothumbnail = block.settings.video2.preview_image
        endif %}
      <video
        width="100%"
        height="auto"
        preload="metadata"
        poster="{{ videothumbnail | image_url }}"
        {% if block.settings.loop2 %}
          loop
        {% endif %}
        {% if block.settings.muted_autoplay2 %}
          muted
        {% endif %}
        playsinline
        disablepictureinpicture
      >
        {% for source in block.settings.video2.sources %}
          <source
            {% if block.settings.muted_autoplay2 %}
              data-
            {% endif -%}
            src="{{ source.url }}"
            type="{{ source.mime_type }}"
          >
        {% endfor %}
      </video>
      {% if block.settings.display_play_btn2 or block.settings.muted_autoplay2 == false %}
        <button class="internal-video__play">
          <div class="play-button color-{{ block.settings.btn_color_scheme2 }}{% if block.settings.btn_animation2 %} ripple-animation{% endif %}">
            {%- render 'icon-play' -%}
          </div>
        </button>
      {% endif %}
      {% if block.settings.display_timeline2 %}
        <div class="internal-video__timeline accent-color-{{ block.settings.timeline_color2 }}">&nbsp</div>
      {% endif %}
      {% if block.settings.display_sound_btn2 %}
        <button class="internal-video__sound-btn flex-center color-{{ block.settings.sound_btn_color_scheme2 }}">
          <svg fill="currentColor" height="12" role="img" viewBox="0 0 48 48" width="12">
            <path clip-rule="evenodd" d="M1.5 13.3c-.8 0-1.5.7-1.5 1.5v18.4c0 .8.7 1.5 1.5 1.5h8.7l12.9 12.9c.9.9 2.5.3 2.5-1v-9.8c0-.4-.2-.8-.4-1.1l-22-22c-.3-.3-.7-.4-1.1-.4h-.6zm46.8 31.4-5.5-5.5C44.9 36.6 48 31.4 48 24c0-11.4-7.2-17.4-7.2-17.4-.6-.6-1.6-.6-2.2 0L37.2 8c-.6.6-.6 1.6 0 2.2 0 0 5.7 5 5.7 13.8 0 5.4-2.1 9.3-3.8 11.6L35.5 32c1.1-1.7 2.3-4.4 2.3-8 0-6.8-4.1-10.3-4.1-10.3-.6-.6-1.6-.6-2.2 0l-1.4 1.4c-.6.6-.6 1.6 0 2.2 0 0 2.6 2 2.6 6.7 0 1.8-.4 3.2-.9 4.3L25.5 22V1.4c0-1.3-1.6-1.9-2.5-1L13.5 10 3.3-.3c-.6-.6-1.5-.6-2.1 0L-.2 1.1c-.6.6-.6 1.5 0 2.1L4 7.6l26.8 26.8 13.9 13.9c.6.6 1.5.6 2.1 0l1.4-1.4c.7-.6.7-1.6.1-2.2z" fill-rule="evenodd"></path>
          </svg>
          <svg fill="currentColor" height="12" role="img" viewBox="0 0 24 24" width="12">
            <path d="M16.636 7.028a1.5 1.5 0 1 0-2.395 1.807 5.365 5.365 0 0 1 1.103 3.17 5.378 5.378 0 0 1-1.105 3.176 1.5 1.5 0 1 0 2.395 1.806 8.396 8.396 0 0 0 1.71-4.981 8.39 8.39 0 0 0-1.708-4.978Zm3.73-2.332A1.5 1.5 0 1 0 18.04 6.59 8.823 8.823 0 0 1 20 12.007a8.798 8.798 0 0 1-1.96 5.415 1.5 1.5 0 0 0 2.326 1.894 11.672 11.672 0 0 0 2.635-7.31 11.682 11.682 0 0 0-2.635-7.31Zm-8.963-3.613a1.001 1.001 0 0 0-1.082.187L5.265 6H2a1 1 0 0 0-1 1v10.003a1 1 0 0 0 1 1h3.265l5.01 4.682.02.021a1 1 0 0 0 1.704-.814L12.005 2a1 1 0 0 0-.602-.917Z"></path>
          </svg>
        </button>
      {% endif %}
    </internal-video>
  {% else %}
    {{ 'image' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
  {% endif %}
</div>

{% schema %}
{
  "name": "Video Player 2",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video",
      "id": "video2",
      "label": "Video"
    },
    {
      "type": "image_picker",
      "id": "thumbnail2",
      "label": "Custom thumbnail",
      "info": "Optional: Upload a custom thumbnail image"
    },
    {
      "type": "header",
      "content": "Video Settings"
    },
    {
      "type": "checkbox",
      "id": "muted_autoplay2",
      "label": "Muted autoplay",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "loop2",
      "label": "Loop video",
      "default": false
    },
    {
      "type": "header",
      "content": "Controls"
    },
    {
      "type": "checkbox",
      "id": "display_play_btn2",
      "label": "Show play button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "display_timeline2",
      "label": "Show timeline",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "display_sound_btn2",
      "label": "Show sound button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "btn_animation2",
      "label": "Play button animation",
      "default": false
    },
    {
      "type": "header",
      "content": "Styling"
    },
    {
      "type": "select",
      "id": "btn_color_scheme2",
      "label": "Play button color scheme",
      "options": [
        {
          "value": "accent-1",
          "label": "Accent 1"
        },
        {
          "value": "accent-2",
          "label": "Accent 2"
        },
        {
          "value": "background-1",
          "label": "Background 1"
        },
        {
          "value": "background-2",
          "label": "Background 2"
        },
        {
          "value": "inverse",
          "label": "Inverse"
        }
      ],
      "default": "accent-1"
    },
    {
      "type": "select",
      "id": "timeline_color2",
      "label": "Timeline color",
      "options": [
        {
          "value": "accent-1",
          "label": "Accent 1"
        },
        {
          "value": "accent-2",
          "label": "Accent 2"
        },
        {
          "value": "background-1",
          "label": "Background 1"
        },
        {
          "value": "background-2",
          "label": "Background 2"
        },
        {
          "value": "inverse",
          "label": "Inverse"
        }
      ],
      "default": "accent-1"
    },
    {
      "type": "select",
      "id": "sound_btn_color_scheme2",
      "label": "Sound button color scheme",
      "options": [
        {
          "value": "accent-1",
          "label": "Accent 1"
        },
        {
          "value": "accent-2",
          "label": "Accent 2"
        },
        {
          "value": "background-1",
          "label": "Background 1"
        },
        {
          "value": "background-2",
          "label": "Background 2"
        },
        {
          "value": "inverse",
          "label": "Inverse"
        }
      ],
      "default": "accent-1"
    },
    {
      "type": "header",
      "content": "Margins"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top",
      "min": 0,
      "max": 45,
      "step": 3,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 45,
      "step": 3,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Video Player 2",
      "category": "Product"
    }
  ]
}
{% endschema %}
