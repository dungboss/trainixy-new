      "min": 0,
      "max": 20,
      "step": 1,
      "default": 10,
      "unit": "px",
      "label": "Image border radius"
    },
    {
      "type": "header",
      "content": "Left side"
    },
    {
      "type": "image_picker",
      "id": "image1",
      "label": "Image 1"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline 1",
      "default": "Headline"
    },
    {
      "type": "inline_richtext",
      "id": "text",
      "label": "Text content",
      "default": "Pair text with an image to focus on your chosen product."
    },
    {
      "type": "header",
      "content": "Leave blank if you don't want to show any point"
    },
    {
      "type": "text",
      "id": "point1",
      "label": "Point 1",
      "default": "Point 1"
    },
    {
      "type": "text",
      "id": "point2",
      "label": "Point 2",
      "default": "Point 2"
    },
    {
      "type": "text",
      "id": "point3",
      "label": "Point 3",
      "default": "Point 3"
    },
    {
      "type": "header",
      "content": "Right side"
    },
    {
      "type": "image_picker",
      "id": "image2",
      "label": "Image 2"
    },
    {
      "type": "text",
      "id": "headline2",
      "label": "Headline 2",
      "default": "Headline"
    },
    {
      "type": "inline_richtext",
      "id": "text2",
      "label": "Text content",
      "default": "Pair text with an image to focus on your chosen product."
    },
    {
      "type": "text",
      "id": "point4",
      "label": "Point 1",
      "default": "Point 1"
    },
    {
      "type": "text",
      "id": "point5",
      "label": "Point 2",
      "default": "Point 2"
    },
    {
      "type": "text",
      "id": "point6",
      "label": "Point 3",
      "default": "Point 3"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Double Image with content"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
