{% comment %}
  Modern electronics store hero section with promotional banners and featured products
{% endcomment %}

<style>
  .super-hero {
    {% if section.settings.enable_gradient %}
      background: linear-gradient(135deg, {{ section.settings.background_color }} 0%, {{ section.settings.secondary_color }} 100%);
    {% else %}
      background: {{ section.settings.background_color | default: '#667eea' }};
    {% endif %}
    color: white;
    padding: 80px 0;
    position: relative;
    overflow: hidden;
  }

  .super-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    {% liquid 
      assign grid_color = section.settings.grid_color | default: '#FFFFFF'
      assign grid_opacity = section.settings.grid_opacity | default: 30
      assign opacity_decimal = grid_opacity | divided_by: 100.0
      assign grid_size = section.settings.grid_size | default: 20
      assign line_thickness = grid_size | divided_by: 10.0
      assign gap_size = grid_size | minus: line_thickness | minus: 1
    %}
    background-image: 
      linear-gradient(90deg, transparent {{ gap_size }}px, {{ grid_color }} {{ line_thickness }}px, transparent {{ grid_size }}px),
      linear-gradient(transparent {{ gap_size }}px, {{ grid_color }} {{ line_thickness }}px, transparent {{ grid_size }}px);
    background-size: {{ grid_size }}px {{ grid_size }}px;
    opacity: {{ opacity_decimal }};
    {% comment %} 调试：强制展示格子以便测试 {% endcomment %}
    border: 1px solid yellow;
  }
    
  {% comment %} CSS变量，方便JavaScript或者高级自定义使用 {% endcomment %}
  .super-hero {
    {% liquid 
      assign grid_color = section.settings.grid_color | default: '#FFFFFF'
      assign grid_opacity = section.settings.grid_opacity | default: 30
      assign opacity_decimal = grid_opacity | divided_by: 100.0
      assign grid_size = section.settings.grid_size | default: 20
    %}
    --grid-color: {{ grid_color }};
    --grid-opacity: {{ opacity_decimal }};
    --grid-size: {{ grid_size }}px;
  }

  .super-hero-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }

  .super-hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .super-hero-text h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    margin: 0 0 1rem;
    line-height: 1.1;
  }

  .super-hero-text p {
    font-size: 1.2rem;
    margin: 0 0 2rem;
    opacity: 0.9;
    line-height: 1.6;
  }

  .super-hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .super-hero-btn {
    padding: 1rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .super-hero-btn--primary {
    background: white;
    color: #667eea;
  }

  .super-hero-btn--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.2);
  }

  .super-hero-btn--secondary {
    background: transparent;
    color: white;
    border: 2px solid white;
  }

  .super-hero-btn--secondary:hover {
    background: white;
    color: #667eea;
  }

  .super-hero-features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .super-hero-feature {
    text-align: center;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 1rem;
    backdrop-filter: blur(10px);
  }

  .super-hero-feature-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .super-hero-feature h3 {
    font-size: 1.1rem;
    margin: 0 0 0.5rem;
    font-weight: 600;
  }

  .super-hero-feature p {
    font-size: 0.9rem;
    margin: 0;
    opacity: 0.8;
  }

  .super-hero-image {
    position: relative;
  }

  .super-hero-image img {
    width: 100%;
    height: auto;
    border-radius: 1rem;
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
  }

  @media (max-width: 768px) {
    .super-hero {
      padding: 60px 0;
    }

    .super-hero-content {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }

    .super-hero-features {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .super-hero-cta {
      justify-content: center;
    }
  }
</style>

<section class="super-hero" {{ section.shopify_attributes }}>
  <div class="super-hero-container">
    <div class="super-hero-content">
      <div class="super-hero-text">
        {% if section.settings.heading != blank %}
          <h1>{{ section.settings.heading }}</h1>
        {% endif %}
        
        {% if section.settings.description != blank %}
          <p>{{ section.settings.description }}</p>
        {% endif %}

        <div class="super-hero-cta">
          {% if section.settings.button_1_text != blank and section.settings.button_1_url != blank %}
            <a href="{{ section.settings.button_1_url }}" class="super-hero-btn super-hero-btn--primary">
              {{ section.settings.button_1_text }}
            </a>
          {% endif %}
          
          {% if section.settings.button_2_text != blank and section.settings.button_2_url != blank %}
            <a href="{{ section.settings.button_2_url }}" class="super-hero-btn super-hero-btn--secondary">
              {{ section.settings.button_2_text }}
            </a>
          {% endif %}
        </div>
      </div>

      <div class="super-hero-image">
        {% if section.settings.hero_image != blank %}
          <img
            src="{{ section.settings.hero_image | image_url: width: 600 }}"
            alt="{{ section.settings.hero_image.alt | escape }}"
            loading="lazy"
            width="600"
            height="400"
          >
        {% else %}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>
    </div>

    <div class="super-hero-features">
      {% for block in section.blocks %}
        <div class="super-hero-feature" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div class="super-hero-feature-icon">
              <span class="material-symbols-outlined">{{ block.settings.icon }}</span>
            </div>
          {% endif %}
          
          {% if block.settings.title != blank %}
            <h3>{{ block.settings.title }}</h3>
          {% endif %}
          
          {% if block.settings.description != blank %}
            <p>{{ block.settings.description }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Super Hero",
  "settings": [
    {
      "type": "header",
      "content": "Background Settings"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#667eea",
      "info": "Primary background color"
    },
    {
      "type": "color",
      "id": "secondary_color",
      "label": "Secondary Color (for gradient)",
      "default": "#764ba2",
      "info": "Used to create gradient effect when enabled"
    },
    {
      "type": "checkbox",
      "id": "enable_gradient",
      "label": "Enable Gradient Background",
      "default": true,
      "info": "Check to use gradient, uncheck for solid color"
    },
    {
      "type": "color",
      "id": "grid_color",
      "label": "Grid Pattern Color",
      "default": "#FFFFFF",
      "info": "Color of the grid overlay pattern"
    },
    {
      "type": "range",
      "id": "grid_opacity",
      "label": "Grid Pattern Opacity",
      "min": 5,
      "max": 100,
      "step": 5,
      "default": 30,
      "unit": "%",
      "info": "Transparency level of grid pattern"
    },
    {
      "type": "range",
      "id": "grid_size",
      "label": "Grid Pattern Size",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 20,
      "unit": "px",
      "info": "Size of each grid cell"
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Premium Electronics & Technology"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover the latest in smartphones, laptops, gaming gear, and smart home devices. Quality products with unbeatable prices."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Primary Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_1_url",
      "label": "Primary Button URL"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Secondary Button Text",
      "default": "View Categories"
    },
    {
      "type": "url",
      "id": "button_2_url",
      "label": "Secondary Button URL"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (Material Symbol)",
          "default": "verified",
          "info": "Use Material Symbols icon name"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Quality Guaranteed"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "All products come with warranty"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Super Hero",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "verified",
            "title": "Quality Guaranteed",
            "description": "All products come with warranty"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "local_shipping",
            "title": "Fast Shipping",
            "description": "Quick delivery across India"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "support_agent",
            "title": "24/7 Support",
            "description": "Expert technical assistance"
          }
        }
      ]
    }
  ]
}
{% endschema %}
