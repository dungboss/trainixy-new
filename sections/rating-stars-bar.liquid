{% schema %}
  {
    "name": "Rating Stars Bar",
    "settings": [

 {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 0.1,
          "default": 4.8
        },
        {
          "type": "color",
          "id": "star_color",
          "default": "#ffcc00",
          "label": "Stars color"
        },
        {
          "type": "select",
          "id": "bg_stars_style",
          "options": [
            {
              "value": "outlined",
              "label": "Outlined"
            },
            {
              "value": "full",
              "label": "Full"
            }
          ],
          "label": "Background stars style",
          "default": "full"
        },
        {
          "type": "color",
          "id": "bg_star_color",
          "default": "#ececec",
          "label": "Background stars color"
        },
        {
          "type": "inline_richtext",
          "id": "label",
          "label": "Text",
          "default": "4.8 | xxxx Happy Customers"
        },
        {
          "type": "range",
          "id": "size",
          "min": 10,
          "max": 24,
          "step": 1,
          "unit": "px",
          "default": 16,
          "label": "Text size"
        },
         {
        "type": "color",
        "id": "ratingstarstextcolor",
        "label": "Text Color",
        "default": "#FFFFFF"
      },

  {
        "type": "color",
        "id": "custombarcolor",
        "label": "Bar Color",
        "default": "#000000"
      },
      {
          "type": "header",
          "content": "Block margin"
        },
        {
          "type": "range",
          "id": "margin_top",
          "min": 0,
          "max": 30,
          "step": 3,
          "unit": "px",
          "label": "Top margin",
          "default": 3
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "min": 0,
          "max": 30,
          "step": 3,
          "unit": "px",
          "label": "Bottom margin",
          "default": 3
        }
],

     "presets": [
    {
      "name": "Rating Stars Bar"
    }
  ]
  }
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}

<style>
  .icon .material-icon.material-symbols-outlined {
      color: {{section.settings.iconcolors }};
  }

      .announcement_bottom_blocks .text p {
 
      color: {{section.settings.iconstextcolor }};
  }
</style>
