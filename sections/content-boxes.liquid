{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    @media screen and (max-width: 479px) {
    .section_meet {
      padding-top: {{ section.settings.padding_topmobile }}px;
      padding-bottom: {{ section.settings.padding_bottommobile }}px;
    }
  }
{%- endstyle -%}


<section id="shopify-section-meetmonke" class="section_meet animate-section animate--hidden {{ section.settings.visibility }} section-{{ section.id }}-padding animate-section" data-content="#shopify-section-{{ section.id }}">
  <div class="container_vertical align-center animate-item animate-item">
    <div class="text_meet">
      <h2 class="h2_heading">{{ section.settings.heading | escape }}</h2>
    </div>
    <div class="content_meet">
   {% if section.settings.frame_1_heading != blank %}
      <div class="frame_meet left_deg">
        <h3 class="h3_heading">{{ section.settings.frame_1_heading | escape }}</h3>
        <p class="paragraph">{{ section.settings.frame_1_text | escape }}</p>
      </div>
      {% endif %}
         {% if section.settings.frame_2_heading != blank %}
      <div class="frame_meet left_deg r-deg">
        <h3 class="h3_heading">{{ section.settings.frame_2_heading | escape }}</h3>
        <p class="paragraph">{{ section.settings.frame_2_text | escape }}</p>
      </div>
      {% endif %}
       {% if section.settings.frame_3_heading != blank %}
      <div class="frame_meet right_deg l-deg">
        <h3 class="h3_heading">{{ section.settings.frame_3_heading | escape }}</h3>
        <p class="paragraph">{{ section.settings.frame_3_text | escape }}</p>
      </div>
       {% endif %}
    </div>
  </div>
</section>

<style>
  .section_meet {
    border-bottom: 1px solid var(--black-3);
    background-color: {{ section.settings.backgroundcolor }};
    position: relative;
    overflow: hidden;
  }
  .container_vertical {
    padding-left: 70px;
    padding-right: 70px;
}
  .text_meet {
    grid-column-gap: 8px;
    grid-row-gap: 8px;
    justify-content: center;
    align-items: center;
    display: flex;
  }
  .h2_heading {
    text-transform: {{ section.settings.headlinetransform }};
    margin-top: 0;
    margin-bottom: 20px;
    font-size: {{ section.settings.headingfontsize }}px;
    font-weight: 400;
    line-height: 100%;
  }
  .span_orange {
    color: var(--orange);
  }
  .content_meet {
    grid-column-gap: 24px;
    grid-row-gap: 24px;
    justify-content: space-between;
    display: flex;
  }
  .frame_meet {
    border: 2px solid var(--orange);
    background-color: #fff;
    border-radius: 16px;
    padding: 24px;
    box-shadow: 6px 6px {{ section.settings.bordercolor }};
  }
  .frame_meet.left_deg {
    grid-column-gap: 20px;
    grid-row-gap: 20px;
    flex-direction: column;
    align-items: flex-start;
    display: flex;
    transform: rotate(-1.5deg);
  }
  .frame_meet.right_deg {
    transform: rotate(1.5deg);
  }
  .frame_meet.right_deg.l-deg {
    grid-column-gap: 20px;
    grid-row-gap: 20px;
    flex-direction: column;
    align-items: flex-start;
    display: flex;
  }
  @media screen and (max-width: 991px) {
    .h2_heading {
      text-align: center;
    }
  }
  @media screen and (max-width: 767px) {
    .content_meet {
      flex-direction: column;
    }
    .frame_meet.left_deg.r-deg {
      transform: rotate(1.5deg);
    }
    .frame_meet.right_deg.l-deg {
      transform: rotate(-1.5deg);
    }
  }
  @media screen and (max-width: 479px) {

  .container_vertical {
    padding: 10px
    }
   
    .container_vertical.align-center {
      grid-column-gap: 24px;
      grid-row-gap: 24px;
    }
    .h3_heading {
      font-size: 24px;
      line-height: 120%;
    }
    .section_meet {
  padding-top: {{ section.settings.padding_topmobile }}px;
      padding-bottom: {{ section.settings.padding_bottommobile }}px;
    }
    .h2_heading {
      font-size: {{ section.settings.headingfontsizemobile }}px;
    }
    .frame_meet.left_deg,
    .frame_meet.right_deg.l-deg {
      z-index: 1;
      grid-column-gap: 0px;
      grid-row-gap: 0px;
      position: relative;
    }
    .paragraph {
      font-size: 14px;
      line-height: 20px;
    }
  }
</style>

{% schema %}
{
  "name": "Content Boxes",
  "settings": [
      {
      "type": "select",
      "id": "visibility",
      "options": [
        {
          "value": "desktop-hidden",
          "label": "Mobile only"
        },
        {
          "value": "mobile-hidden",
          "label": "Desktop only"
        },
        {
          "value": "always-display",
          "label": "All devices"
        }
      ],
      "label": "Display on",
      "default": "always-display"
    },
    {
      "type": "header",
      "content": "Section Heading"
    },
        {
      "type": "color",
      "id": "backgroundcolor",
      "label": "Background Color",
      "default": "#F3F3F3"
    },
    {
      "type": "color",
      "id": "bordercolor",
      "label": "Border Color",
      "default": "#000000"
    },

    {
      "id": "heading",
      "type": "text",
      "label": "Heading",
      "default": "Headline"
    },

       {
      "type": "select",
      "id": "headlinetransform",
      "options": [
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "normal",
          "label": "Normal"
        }
      ],
      "default": "uppercase",
      "label": "Heading style"
    }, 
      {
      "type": "range",
      "id": "headingfontsize",
      "min": 16,
      "max": 56,
      "step": 1,
      "unit": "px",
      "label": "Heading font size",
      "default": 46
    },
     {
      "type": "range",
      "id": "headingfontsizemobile",
      "min": 16,
      "max": 56,
      "step": 1,
      "unit": "px",
      "label": "Mobile Heading font size",
      "default": 36
    },    
    {
      "type": "paragraph",
      "content": "Content boxes"
    },
    {
      "id": "frame_1_heading",
      "type": "text",
      "label": "Box 1 Heading",
      "default": "Headline 1"
    },
    {
      "id": "frame_1_text",
      "type": "textarea",
      "label": "Content 1 Text",
      "default": "Enter text to talk about your product heading, feature or benefit."
    },
    {
      "id": "frame_2_heading",
      "type": "text",
      "label": "Box 2 Heading",
      "default": "Heading 2"
    },
    {
      "id": "frame_2_text",
      "type": "textarea",
      "label": "Content 2 Text",
      "default": "Enter text to talk about your product heading, feature or benefit."
    },
    {
      "id": "frame_3_heading",
      "type": "text",
      "label": "Box 3 Heading",
      "default": "Heading 3"
    },
    {
      "id": "frame_3_text",
      "type": "textarea",
      "label": "Content 3 Text",
      "default": "Enter text to talk about your product heading, feature or benefit."
    },
      {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 72
    },
         {
      "type": "header",
      "content": "Mobile padding"
    },
    {
      "type": "range",
      "id": "padding_topmobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 22
    },
    {
      "type": "range",
      "id": "padding_bottommobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 22
    }
  ],
  "presets": [
    {
      "name": "Content Boxes"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
