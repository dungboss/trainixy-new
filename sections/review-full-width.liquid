<section class="section bg-white pro-richtext section-{{ section.id }}-padding">
  <div class="isolate page-width">
    <div
      class="rich-text content-container section-rich-text-padding"
      style="background: {{ section.settings.reviewbackground }};  border-radius: {{section.settings.borderradius}}px;"
    >
      <div class="reviews-carucel">
        <div class="rich-text__blocks text-center" style="max-width: 100%;">
          <div class="reviewer-image">
            <img src="{{ section.settings.image | img_url:'medium' }}">
          </div>
          <div class="white-starsec">
            <center>
              <div
                class="rating-stars"
                style="--rating:{{ section.settings.rating }};--star-color:{{ section.settings.star_color }};--bg-star-color:{{ section.settings.bg_star_color }};--font-size:{{ section.settings.size | divided_by: 10.0 }}rem;--alignment:{{ section.settings.alignment }}; margin-top: {{ section.settings.margin_top | divided_by: 10.0 }}rem; margin-bottom: {{ section.settings.margin_bottom | divided_by: 10.0 }}rem;"
              >
                <div class="rating-stars-and-text font-size--desktop-auto flex-center">
                  <div class="rating-stars__container rating-stars__container--underlay">
                    {% if section.settings.bg_stars_style == 'outlined' %}
