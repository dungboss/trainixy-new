          </div>
          <h2 class="h2" style="font-size:{{section.settings.titlesize}}px;font-weight: normal;">
            {{ section.settings.title }}
          </h2>

          <div class="authr_name">
            <span class="text_authr">{{ section.settings.reviewname }}</span>

         {% if section.settings.enableverifiedbuyer %}<strong> <i class="fa fa-check-circle" aria-hidden="true"></i>{{ section.settings.verifiedbuyer }}</strong>  {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}
{% schema %}
{
  "name": "Review",
  "class": "section",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "rating",
      "label": "Rating",
      "min": 1,
      "max": 5,
      "step": 0.1,
      "default": 5
    },
    {
      "type": "color",
      "id": "star_color",
      "default": "#ffcc00",
      "label": "Stars color"
    },
    {
      "type": "select",
      "id": "bg_stars_style",
      "options": [
        {
          "value": "outlined",
          "label": "Outlined"
        },
        {
          "value": "full",
          "label": "Full"
        }
      ],
      "label": "Background stars style",
      "default": "full"
    },
    {
      "type": "color",
      "id": "bg_star_color",
      "default": "#ececec",
      "label": "Background stars color"
    },
    {
      "type": "range",
      "id": "size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16,
      "label": "Text size"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "center"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "“Enter your review text here.”"
    },
    {
      "type": "range",
      "id": "titlesize",
      "min": 17,
      "max": 19,
      "step": 1,
      "unit": "px",
      "default": 19,
      "label": "Text size"
    },
    {
      "type": "text",
      "id": "reviewname",
      "label": "Name",
      "default": "Jane M."
    },
    {
          "type": "checkbox",
          "id": "enableverifiedbuyer",
          "default": true,
          "label": "Enable verified buyer"
    },
    {
      "type": "text",
      "id": "verifiedbuyer",
      "default": "Verified Buyer",
      "label": "Verified Buyer"
    },
    {
      "type": "color",
      "id": "checkcolor",
      "label": "Checkmark Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "reviewbackground",
      "label": "Background Color",
      "default": "#fafafa"
    },
      {
      "type": "color",
      "id": "sectionbackgroundcolor",
      "label": "Section background Color",
      "default": "#FFFFFF"
    },
      {
      "type": "range",
      "id": "borderradius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0,
      "label": "Corner radius"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Review"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}

<style>
    .authr_name .fa-check-circle:before {
      content: "\f058" !important;
    }

      .authr_name strong {
      display: inline-block;
      vertical-align: middle;
      margin-left: 2px;
      font-size: 14px;
      line-height: 14px;
      color: black;
    }
    .authr_name i {
      display: inline-block;
      vertical-align: middle;
      font-size: 14px;
      line-height: 14px;
      color: {{section.settings.checkcolor}};
      margin-right: 7px;
    }


  
    .white-starsec {
      font-size: 30px;
      line-height: 30px;
    }
    .reviewer-image img {
      margin: 0 auto 20px;
      width: 100px;
      height: 100px;
      object-fit: cover;
      border-radius: 50%;
      border: 4px solid #fff;
    }
    .check-box-new:before {
      top: 2px;
      content: "";
      position: absolute;
      background-image: url(https://cdn.shopify.com/s/files/1/0609/1531/8959/files/icon-arrow-verify.svg?v=1663069824);
      width: 20px;
      height: 20px;
      left: 0;
      object-fit: cover;
      background-repeat: no-repeat;
    }
    .check-box-new {
      width: fit-content;
      margin: auto;
      position: relative;
      display: inline;
      padding-left: 25px;
      color: #fff;
    }

    .bg-white {
      background-color: {{section.settings.sectionbackgroundcolor}};
    }

    .text-center {
      text-align: center;
    }
    .pro-richtext .rich-text {
      padding: 30px 25px 39px 25px;
    }
    @media screen and (min-width: 750px) {
      .pro-richtext .rich-text {
        padding-top: 40px;
        padding-bottom: 52px;
      }
    }
  
  .rich-text__text i {
      display: inline-block;
      vertical-align: middle;
      font-size: 14px;
      line-height: 14px;
      color: {{section.settings.checkcolor}};
      margin-right: 7px;
    }
</style>
